    ),
  ];

  /// ดึงคำถามทั้งหมดตาม level (1-based index)
  static List<QuestionTemplate> getQuestionsByLevel(int level) {
    if (level <= 0 || level > 5) {
      return bank.where((q) => q.level == 5).toList();
    }
    return bank.where((q) => q.level == level).toList();
  }

  /// ดึงคำถามเดี่ยวตาม index (สำหรับ backward compatibility)
  static QuestionTemplate getQuestion(int index) {
    if (index <= 0 || index > bank.length) {
      return bank.last;
    }
    return bank[index - 1];
  }

  /// จำนวนด่านทั้งหมด
  static int get totalLevels => 5;
}
