{
  "buildCommand": "flutter build web --release",
  "installCommand": "flutter pub get",
  "outputDirectory": "build/web",
  "framework": "flutter",
  "routes": [
    {
      "src": "/privacy",
      "dest": "/privacy.html",
      "status": 200
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
